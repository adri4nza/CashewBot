# ==========================================
# 🤖 CREDENCIALES DE APIS (Para los nodos de n8n)
# ==========================================

# Token de tu bot en Telegram (Obtenido desde @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_de_telegram_aqui

# API Key de Google Gemini (Obtenido desde Google AI Studio)
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# Credenciales de Google Cloud Console (Para Google Sheets OAuth2)
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui

# ID de la hoja de cálculo de Google Sheets (CashewBot DB)
# Es el texto largo en la URL de tu Google Sheet: https://docs.google.com/spreadsheets/d/AQUI_ESTA_EL_ID/edit
SPREADSHEET_ID=tu_spreadsheet_id_aqui


# ==========================================
# 🌐 CONFIGURACIÓN DEL SERVIDOR N8N (Para Docker Compose)
# ==========================================

# Zona horaria para que el CRON y las fechas del bot coincidan con tu país
GENERIC_TIMEZONE=America/Caracas

# URL pública de tu servidor (CRÍTICO para que Telegram pueda enviar los mensajes al Webhook de n8n)
WEBHOOK_URL=https://n8n.tudominio.com # O la IP de DigitalOcean si no usas dominio