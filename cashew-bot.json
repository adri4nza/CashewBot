    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet mensaje = \"📝 <b>Tus transacciones pendientes:</b>\\n\\n\";\nlet contador = 0;\n\nfor (const item of items) {\n  const fila = item.json;\n  \n  // Verificamos que la fila tenga datos reales\n  if(fila.ID) { \n    contador++;\n    mensaje += `🔸 <b>${fila.Titulo}</b>: ${fila.Monto}\\n`;\n    \n    // Agregamos categoría si existe\n    if(fila.Categoria) {\n      let sub = fila.Subcategoria ? ` ➡️ ${fila.Subcategoria}` : '';\n      mensaje += `   └ <i>${fila.Categoria}${sub}</i>\\n`;\n    }\n    // Agregamos cuenta si existe\n    if(fila.Cuenta) {\n      mensaje += `   └ 🏦 <i>${fila.Cuenta}</i>\\n`;\n    }\n    mensaje += \"\\n\"; \n  }\n}\n\nmensaje += `Total: <b>${contador}</b> registro(s) esperando.\\n`;\nmensaje += `👉 Usa /guardar_dia para enviarlos a Cashew.`;\n\nreturn [{\n  json: { textoFormateado: mensaje }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
