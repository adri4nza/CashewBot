      "parameters": {
        "jsCode": "// Rescatamos los IDs usando .first() como pide n8n\nconst ids = $('Code procesar pendientes').first().json.idsActualizar;\n\n// Convertimos esa lista en \"Items\" individuales que n8n pueda procesar\nreturn ids.map(id => {\n  return { \n    json: { ID_Gasto: id } \n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        992,
        -1184
      ],
      "id": "53f31d24-7cde-4c83-ac04-dfd0835b339b",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "// 1. Extraemos y parseamos los datos de Gemini\nconst rawText = $input.first().json.content.parts[0].text;\nconst data = JSON.parse(rawText);\n\n// 2. Generamos datos de control para la base de datos\ndata.id = Date.now().toString(); // Un ID único basado en el milisegundo actual\n// Usamos la zona horaria de Venezuela para que la fecha sea exacta\ndata.fecha = new Date().toLocaleString(\"es-VE\", { timeZone: \"America/Caracas\" }); \ndata.estado = \"Pendiente\";\n\n// 3. Devolvemos los datos limpios\nreturn { json: data };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        320,
        -416
      ],
      "id": "ed2983e5-a375-4286-9aed-4cfb7f63bbfa",
      "name": "Code procesar gemini"
    },
    {
      "parameters": {
        "jsCode": "// 1. Obtenemos todas las filas que encontró Google Sheets\nconst items = $input.all();\nconst transacciones = [];\nconst idsActualizar = []; // Guardaremos los IDs para marcarlos como \"Guardados\" más adelante\n\n// 2. Recorremos cada fila para armar los objetos\nfor (const item of items) {\n  const fila = item.json;\n\n  // Armamos el objeto base asegurando que el monto sea un string (como pide Cashew)\n  let gasto = {\n    amount: fila.Monto.toString(),\n    title: fila.Titulo\n  };\n\n  // Agregamos las categorías y cuentas solo si la celda no está vacía\n  if (fila.Categoria) gasto.category = fila.Categoria;\n  if (fila.Subcategoria) gasto.subcategory = fila.Subcategoria;\n  if (fila.Cuenta) gasto.account = fila.Cuenta;\n\n  transacciones.push(gasto);\n  idsActualizar.push(fila.ID); \n}\n\n// 3. Armamos el objeto maestro JSON con el arreglo \"transactions\"\nconst payload = {\n  transactions: transacciones\n};\n\n// 4. Codificamos el JSON completo a formato URL\nconst jsonString = JSON.stringify(payload);\nconst encodedJSON = encodeURIComponent(jsonString);\n\n// 5. Construimos el App Link final\nconst deepLink = `https://cashewapp.web.app/addTransaction?JSON=${encodedJSON}`;\n\n// 6. Devolvemos un ÚNICO paquete de datos al siguiente nodo\nreturn [{\n  json: {\n    deepLink: deepLink,\n    cantidad: transacciones.length,\n    idsActualizar: idsActualizar\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        544,
        -1184
      ],
      "id": "5d52e808-2dc6-4470-b9ac-2e496fcc47c8",
      "name": "Code procesar pendientes"
    },
